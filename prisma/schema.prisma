generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Stock {
  id        Int       @id @default(autoincrement())
  ticker    String    @unique @db.VarChar(20)
  name      String    @db.VarChar(255)
  sector    String    @db.VarChar(100)
  listingBoard String? @db.VarChar(50)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Company profile (from IDX)
  subSector    String?   @db.VarChar(100)
  listingDate  DateTime? @db.Date
  address      String?   @db.VarChar(500)
  website      String?   @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  email        String?   @db.VarChar(100)
  logo         String?   @db.VarChar(500)

  // Enhanced profile (from IDX detail API)
  industry     String?   @db.VarChar(100)
  subIndustry  String?   @db.VarChar(100)
  fax          String?   @db.VarChar(50)
  npwp         String?   @db.VarChar(50)
  businessActivity String? @db.VarChar(500)

  // Trading info (from IDX trading API)
  listedShares             BigInt?
  foreignOwnershipPercent  Decimal? @db.Decimal(6, 2)
  isinCode                 String?  @db.VarChar(20)

  prices       StockPrice[]
  indicators   StockIndicator[]
  fundamentals StockFundamental[]
  shareholders StockShareholder[]
  directors    StockDirector[]
  commissioners StockCommissioner[]
  subsidiaries   StockSubsidiary[]
  dividends      StockDividend[]
  watchlist    Watchlist[]
  paperPositions PaperPosition[]
  paperOrders    PaperOrder[]
  portfolioHoldings PortfolioHolding[]
  @@index([isinCode])

  @@index([sector])
  @@index([isActive])
  @@index([listingBoard])
}

model StockPrice {
  id       Int      @id @default(autoincrement())
  stockId  Int
  date     DateTime @db.Date
  open     Decimal  @db.Decimal(12, 2)
  high     Decimal  @db.Decimal(12, 2)
  low      Decimal  @db.Decimal(12, 2)
  close    Decimal  @db.Decimal(12, 2)
  volume   BigInt
  adjClose Decimal? @db.Decimal(12, 2)

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([stockId, date(sort: Desc)])
  @@index([date])
}

model StockIndicator {
  id         Int      @id @default(autoincrement())
  stockId    Int
  date       DateTime @db.Date
  interval   String   @db.VarChar(10)

  sma20      Decimal? @db.Decimal(12, 2)
  sma50      Decimal? @db.Decimal(12, 2)
  sma200     Decimal? @db.Decimal(12, 2)
  ema12      Decimal? @db.Decimal(12, 2)
  ema26      Decimal? @db.Decimal(12, 2)

  rsi14      Decimal? @db.Decimal(8, 2)
  macdLine   Decimal? @db.Decimal(12, 4)
  macdSignal Decimal? @db.Decimal(12, 4)
  macdHist   Decimal? @db.Decimal(12, 4)

  bbUpper    Decimal? @db.Decimal(12, 2)
  bbMiddle   Decimal? @db.Decimal(12, 2)
  bbLower    Decimal? @db.Decimal(12, 2)

  stochK          Decimal?  @db.Decimal(8, 2)
  stochD          Decimal?  @db.Decimal(8, 2)
  adx             Decimal?  @db.Decimal(8, 2)
  vwap            Decimal?  @db.Decimal(12, 2)
  atr             Decimal?  @db.Decimal(12, 2)
  obv             Decimal?  @db.Decimal(16, 2)
  obvTrend        String?   @db.VarChar(15)
  supertrend      Decimal?  @db.Decimal(12, 2)
  smaCrossSignal  String?   @db.VarChar(20)
  smaCrossDate    DateTime? @db.Date
  emaCrossSignal  String?   @db.VarChar(20)
  emaCrossDate    DateTime? @db.Date

  signalScore     Decimal?  @db.Decimal(5, 2)
  signalLabel     String?   @db.VarChar(20)
  isGorengan      Boolean   @default(false)

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date, interval])
  @@index([stockId, date(sort: Desc)])
  @@index([stockId, interval, date(sort: Desc)])
  @@index([interval, date])
}

model StockFundamental {
  id            Int      @id @default(autoincrement())
  stockId       Int
  date          DateTime @db.Date
  pe            Decimal? @db.Decimal(10, 2)
  forwardPe     Decimal? @db.Decimal(10, 2)
  pb            Decimal? @db.Decimal(10, 2)
  eps           Decimal? @db.Decimal(12, 2)
  dividendYield Decimal? @db.Decimal(6, 4)
  marketCap     BigInt

  // Extended fields (from Yahoo Finance)
  sharesOutstanding        BigInt?
  beta                     Decimal?  @db.Decimal(8, 4)
  averageDailyVolume3Month BigInt?
  bookValue                Decimal?  @db.Decimal(12, 2)

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([date, pe])
  @@index([date, dividendYield])
  @@index([date, marketCap])
}

model StockShareholder {
  id        Int      @id @default(autoincrement())
  stockId   Int
  name      String   @db.VarChar(255)
  type      String?  @db.VarChar(100)
  shares    Decimal? @db.Decimal(20, 2)
  percent   Decimal? @db.Decimal(6, 2)
  updatedAt DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
}

model StockDirector {
  id          Int      @id @default(autoincrement())
  stockId     Int
  name        String   @db.VarChar(255)
  position    String   @db.VarChar(100)
  type        String   @db.VarChar(20)
  independent Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
}

model StockCommissioner {
  id          Int      @id @default(autoincrement())
  stockId     Int
  name        String   @db.VarChar(255)
  position    String?  @db.VarChar(100)
  independent Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
}

model StockSubsidiary {
  id               Int      @id @default(autoincrement())
  stockId          Int
  name             String   @db.VarChar(255)
  businessType     String?  @db.VarChar(255)
  totalAssets      Decimal? @db.Decimal(20, 2)
  ownershipPercent Decimal? @db.Decimal(6, 2)
  updatedAt        DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
}

model StockDividend {
  id          Int       @id @default(autoincrement())
  stockId     Int
  year        Int
  type        String    @db.VarChar(20)
  currency    String?   @db.VarChar(10)
  amount      Decimal?  @db.Decimal(12, 4)
  totalAmount Decimal?  @db.Decimal(20, 2)
  cumDate     DateTime? @db.Date
  exDate      DateTime? @db.Date
  recordDate  DateTime? @db.Date
  paymentDate DateTime? @db.Date
  updatedAt   DateTime  @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, year, type])
  @@index([stockId, year(sort: Desc)])
  @@index([stockId, type])
}

model CachedApiCall {
  id        Int      @id @default(autoincrement())
  cacheKey  String   @unique @db.VarChar(255)
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ── Auth (NextAuth) ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  username      String    @unique
  image         String?
  bio           String?   @db.VarChar(200)
  socialLinks   Json?
  role          Role      @default(USER)
  reputation   Int       @default(0)
  lastDailyClaimAt DateTime?
  dailyStreak      Int      @default(0)
  customTitle   String?  @db.VarChar(30)
  bannedAt      DateTime?
  sessionVersion Int      @default(0)
  portfolioPublic Boolean @default(false)
  createdAt     DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  posts              Post[]
  comments           Comment[]
  watchlist          Watchlist[]
  likes              Like[]
  reports            Report[]
  following          Follow[]          @relation("Following")
  followers          Follow[]          @relation("Followers")
  blocking           Block[]           @relation("Blocking")
  blocked            Block[]           @relation("Blocked")
  stockFollows       StockFollow[]
  notifications      Notification[]    @relation("Notifications")
  notificationActions Notification[]   @relation("NotificationActions")
  bookmarks          Bookmark[]
  reposts            Repost[]
  reactions          Reaction[]
  pollVotes          PollVote[]
  articles           Article[]
  auditLogs          AuditLog[]
  imageGenJobs       ImageGenerationJob[]
  portfolioHoldings  PortfolioHolding[]
  achievements       Achievement[]
  paperAccount       PaperAccount?
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String @id @default(cuid())
  sessionToken String @unique
  userId       String
  expires      DateTime
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Community ────────────────────────────────────────────

model Post {
  id            String   @id @default(cuid())
  content       String   @db.VarChar(1000)
  tickerTag     String?  @db.VarChar(20)
  authorId      String
  imageUrl      String?  @db.VarChar(1000)
  likesCount         Int      @default(0)
  commentsCount      Int      @default(0)
  repostsCount       Int      @default(0)
  predictionTarget    Decimal?  @db.Decimal(12, 2)
  predictionDirection String?   @db.VarChar(10)
  predictionOutcome   String?   @db.VarChar(10)
  predictionResolvedAt DateTime?
  createdAt           DateTime  @default(now())
  pinned              Boolean   @default(false)

  author             User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  notifications Notification[]
  imageGenJobs  ImageGenerationJob[]
  tags          PostTag[]
  reposts       Repost[]
  reactions     Reaction[]
  poll         Poll?

  @@index([tickerTag])
  @@index([createdAt(sort: Desc)])
  @@index([authorId])
  @@index([authorId, createdAt(sort: Desc)])
}

model PostTag {
  id     String @id @default(cuid())
  postId String
  tag    String @db.VarChar(50)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, tag])
  @@index([tag])
  @@index([postId])
}

model Repost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([createdAt(sort: Desc)])
}

model ImageGenerationJob {
  id               String    @id @default(cuid())
  prompt           String    @db.VarChar(2000)
  source           String    @db.VarChar(20)
  status           String    @default("pending")
  comfyuiPromptId  String?
  outputFilename   String?   @db.VarChar(500)
  imageUrl         String?   @db.VarChar(1000)
  error            String?   @db.VarChar(500)
  requestedBy      String
  postId           String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  requester User?  @relation(fields: [requestedBy], references: [id], onDelete: Cascade)
  post      Post?  @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([requestedBy])
  @@index([createdAt(sort: Desc)])
}

model Comment {
  id          String    @id @default(cuid())
  content     String    @db.VarChar(500)
  authorId    String
  postId      String?
  stockTicker String?   @db.VarChar(20)
  parentId    String?
  createdAt   DateTime  @default(now())

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post        Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  notifications Notification[]

  @@index([postId])
  @@index([stockTicker])
  @@index([parentId])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

model Watchlist {
  id          String   @id @default(cuid())
  userId      String
  stockTicker String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockTicker], references: [ticker], onDelete: Cascade)

  @@unique([userId, stockTicker])
}

model PortfolioHolding {
  id          String   @id @default(cuid())
  userId      String
  stockTicker String
  buyPrice    Decimal  @db.Decimal(12, 2)
  quantity    Int
  buyDate     DateTime @db.Date
  notes       String?  @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockTicker], references: [ticker], onDelete: Cascade)

  @@unique([userId, stockTicker])
  @@index([userId])
  @@index([stockTicker])
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

enum ReactionType {
  LIKE
  BULLISH
  BEARISH
  INSIGHTFUL
  ROCKET
  FIRE
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

model Poll {
  id        String    @id @default(cuid())
  postId    String    @unique
  createdAt DateTime  @default(now())
  closesAt  DateTime?

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([createdAt(sort: Desc)])
}

model PollOption {
  id         String @id @default(cuid())
  pollId     String
  text       String @db.VarChar(100)
  order      Int    @default(0)
  votesCount Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId, order])
}

model PollVote {
  id        String   @id @default(cuid())
  optionId  String
  pollId    String
  userId    String
  createdAt DateTime @default(now())

  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pollId])
  @@index([optionId])
}

// ── Moderation ───────────────────────────────────────────

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetType ReportTarget
  targetId   String
  reason     ReportReason
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum ReportTarget {
  POST
  COMMENT
}

enum ReportReason {
  SPAM
  ABUSE
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// ── Social ──────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Block {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker User @relation("Blocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@index([blockerId])
}

model StockFollow {
  id        String   @id @default(cuid())
  userId    String
  ticker    String   @db.VarChar(20)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([ticker])
  @@index([userId])
}

enum NotificationType {
  LIKE
  COMMENT
  MENTION
  FOLLOW
  STOCK_POST
  REACTION
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  recipientId String
  actorId     String
  postId      String?
  commentId   String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User     @relation("Notifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User     @relation("NotificationActions", fields: [actorId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([recipientId, read, createdAt(sort: Desc)])
  @@index([actorId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum ArticleType {
  STOCK_ANALYSIS
  EDUCATIONAL
  NEWS
  GENERAL
  DAILY_SNAPSHOT
}

model Article {
  id             String        @id @default(cuid())
  slug           String        @unique @db.VarChar(255)
  title          String        @db.VarChar(255)
  excerpt        String        @db.VarChar(500)
  coverImageUrl  String?       @db.VarChar(1000)
  content        String        @db.Text
  authorId       String
  tags           String[]      @default([])
  status         ArticleStatus @default(DRAFT)
  articleType    ArticleType   @default(STOCK_ANALYSIS)
  aiProvider     String?       @db.VarChar(20)
  tickerTag      String?       @db.VarChar(20)
  generationMeta Json?
  version         Int           @default(1)
  lastGeneratedAt DateTime      @default(now())
  isListed        Boolean       @default(true)
  publishedAt    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([publishedAt])
  @@index([status, articleType])
  @@index([tickerTag])
  @@index([articleType, tickerTag, lastGeneratedAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  action    String   @db.VarChar(100)
  details   Json?
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  type       String   @db.VarChar(50)
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// ── Paper Trading ─────────────────────────────────────────

enum PaperTradeSide {
  BUY
  SELL
}

enum PaperPositionStatus {
  OPEN
  CLOSED
}

enum PaperOrderType {
  MARKET
  LIMIT
  STOP
}

enum PaperOrderStatus {
  PENDING
  FILLED
  CANCELLED
}

enum PaperMood {
  CONFIDENT
  UNCERTAIN
  GREEDY
  FEARFUL
  NEUTRAL
}

model PaperAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  balance         Decimal  @db.Decimal(16, 2)
  initialBalance  Decimal  @db.Decimal(16, 2)
  isPublic        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions  PaperPosition[]
  orders     PaperOrder[]

  @@index([userId])
}

model PaperPosition {
  id              String   @id @default(cuid())
  accountId       String
  stockTicker     String
  side            PaperTradeSide   @default(BUY)
  entryPrice      Decimal  @db.Decimal(12, 2)
  quantity        Int
  status          PaperPositionStatus @default(OPEN)

  stopLossPrice   Decimal? @db.Decimal(12, 2)
  takeProfitPrice Decimal? @db.Decimal(12, 2)

  reason          String?  @db.VarChar(500)
  strategyTags    Json?
  mood            PaperMood?

  closePrice      Decimal? @db.Decimal(12, 2)
  realizedPnl     Decimal? @db.Decimal(16, 2)
  realizedPnlPct  Decimal? @db.Decimal(8, 2)

  openedAt        DateTime @default(now())
  closedAt        DateTime?

  account         PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stock           Stock        @relation(fields: [stockTicker], references: [ticker], onDelete: Cascade)

  @@index([accountId])
  @@index([stockTicker])
  @@index([status])
}

model PaperOrder {
  id           String          @id @default(cuid())
  accountId    String
  stockTicker  String
  side         PaperTradeSide
  orderType    PaperOrderType
  quantity     Int
  targetPrice  Decimal         @db.Decimal(12, 2)
  status       PaperOrderStatus @default(PENDING)

  positionId   String?

  reason       String?         @db.VarChar(500)
  strategyTags Json?
  mood         PaperMood?

  filledAt     DateTime?
  filledPrice  Decimal?        @db.Decimal(12, 2)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  account      PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stock        Stock        @relation(fields: [stockTicker], references: [ticker], onDelete: Cascade)

  @@index([accountId])
  @@index([status])
  @@index([stockTicker, status])
}
